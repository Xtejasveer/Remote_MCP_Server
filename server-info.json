{
  "server": {
    "name": "Simple Calculator server",
    "instructions": null,
    "version": "3.4.4",
    "website_url": null,
    "icons": null,
    "generation": 2,
    "capabilities": {
      "tools": {
        "listChanged": true
      },
      "resources": {
